// This file defines your database tables.
// After any change here, run: npx prisma migrate dev --name your-change-name

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // stored as a bcrypt hash, never plain text
  createdAt DateTime @default(now())

  // A user can be a member of many trips
  memberships TripMember[]
}

model Trip {
  id          String   @id @default(cuid())
  groupName   String
  destination String
  emoji       String   @default("✈️")
  arrival     DateTime
  completed   Boolean  @default(false)
  departure   DateTime
  isSolo      Boolean  @default(false)
  shareCode   String   @unique
  coverUrl    String?
  budget      Float?
  createdAt   DateTime @default(now())

  // Relations
  members   TripMember[]
  expenses  Expense[]
  contacts  Contact[]
  photos    Photo[]
  itinerary ItineraryItem[]
}

// Join table: which users belong to which trip
model TripMember {
  id       String   @id @default(cuid())
  tripId   String
  userId   String
  nickname String // display name inside the trip (e.g. "Arjun")
  joinedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model Expense {
  id         String   @id @default(cuid())
  tripId     String
  desc       String
  amount     Float
  paidBy     String // nickname of the person who paid
  cat        String // food | transport | stay | activity | shopping | other
  split      String[] // array of nicknames who share this expense
  note       String?
  date       DateTime @default(now())
  receiptUrl String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Contact {
  id      String  @id @default(cuid())
  tripId  String
  name    String
  role    String
  cat     String // guardian | driver | hotel | guide | medical | emergency | other
  phone   String
  addedBy String // nickname
  note    String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  tripId    String
  url       String
  uploader  String // nickname
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model ItineraryItem {
  id     String  @id @default(cuid())
  tripId String
  day    Int // day number: 1, 2, 3...
  time   String? // e.g. "09:00 AM"
  title  String
  note   String?
  icon   String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
