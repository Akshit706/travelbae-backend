// This file defines your database tables.
// After any change here, run: npx prisma migrate dev --name your-change-name

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // stored as a bcrypt hash, never plain text
  createdAt DateTime @default(now())

  // A user can be a member of many trips
  memberships      TripMember[]
  clubProfiles     ClubProfile[]     @relation("ClubProfileCreator")
  clubRequests     ClubJoinRequest[] @relation("ClubRequestSenderUser")
  clubChatMessages ClubChatMessage[] @relation("ClubChatMessageSenderUser")
}

model Trip {
  id          String   @id @default(cuid())
  groupName   String
  destination String
  emoji       String   @default("✈️")
  arrival     DateTime
  completed   Boolean  @default(false)
  departure   DateTime
  isSolo      Boolean  @default(false)
  shareCode   String   @unique
  coverUrl    String?
  budget      Float?
  createdAt   DateTime @default(now())

  // Relations
  members              TripMember[]
  expenses             Expense[]
  contacts             Contact[]
  photos               Photo[]
  itinerary            ItineraryItem[]
  clubProfile          ClubProfile?
  clubRequestsSent     ClubJoinRequest[] @relation("ClubRequestSenderTrip")
  clubRequestsReceived ClubJoinRequest[] @relation("ClubRequestTargetTrip")
  clubChatsA           ClubChat[]        @relation("ClubChatTripA")
  clubChatsB           ClubChat[]        @relation("ClubChatTripB")
  clubChatMessages     ClubChatMessage[] @relation("ClubChatMessageSenderTrip")
}

// Join table: which users belong to which trip
model TripMember {
  id       String   @id @default(cuid())
  tripId   String
  userId   String
  nickname String // display name inside the trip (e.g. "Arjun")
  joinedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model Expense {
  id         String   @id @default(cuid())
  tripId     String
  desc       String
  amount     Float
  paidBy     String // nickname of the person who paid
  cat        String // food | transport | stay | activity | shopping | other
  split      String[] // array of nicknames who share this expense
  note       String?
  date       DateTime @default(now())
  receiptUrl String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Contact {
  id      String  @id @default(cuid())
  tripId  String
  name    String
  role    String
  cat     String // guardian | driver | hotel | guide | medical | emergency | other
  phone   String
  addedBy String // nickname
  note    String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  tripId    String
  url       String
  uploader  String // nickname
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model ItineraryItem {
  id     String  @id @default(cuid())
  tripId String
  day    Int // day number: 1, 2, 3...
  time   String? // e.g. "09:00 AM"
  title  String
  note   String?
  icon   String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model ClubProfile {
  id            String   @id @default(cuid())
  tripId        String   @unique
  creatorUserId String
  status        String   @default("listed") // listed | snooze
  title         String
  about         String
  lookingFor    String?
  photoUrl      String? // profile photo for club (base64 or URL)
  latitude      Float? // location latitude for distance filtering
  longitude     Float? // location longitude for distance filtering
  vibe          String? // chill | adventure | party | foodie | culture | mixed
  genderMix     String? // mixed | all-boys | all-girls
  boysCount     Int?
  girlsCount    Int?
  coverTags     String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trip    Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  creator User @relation("ClubProfileCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([latitude, longitude])
}

model ClubJoinRequest {
  id              String   @id @default(cuid())
  targetTripId    String
  requesterTripId String
  requesterUserId String
  message         String
  status          String   @default("pending") // pending | accepted | declined
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  targetTrip    Trip @relation("ClubRequestTargetTrip", fields: [targetTripId], references: [id], onDelete: Cascade)
  requesterTrip Trip @relation("ClubRequestSenderTrip", fields: [requesterTripId], references: [id], onDelete: Cascade)
  requesterUser User @relation("ClubRequestSenderUser", fields: [requesterUserId], references: [id], onDelete: Cascade)

  @@unique([targetTripId, requesterTripId])
  @@index([targetTripId, status])
  @@index([requesterTripId, status])
}

model ClubChat {
  id        String   @id @default(cuid())
  tripAId   String
  tripBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripA         Trip                   @relation("ClubChatTripA", fields: [tripAId], references: [id], onDelete: Cascade)
  tripB         Trip                   @relation("ClubChatTripB", fields: [tripBId], references: [id], onDelete: Cascade)
  messages      ClubChatMessage[]
  splitExpenses ClubChatSplitExpense[]

  @@unique([tripAId, tripBId])
  @@index([tripAId])
  @@index([tripBId])
}

model ClubChatMessage {
  id           String   @id @default(cuid())
  chatId       String
  senderTripId String
  senderUserId String
  text         String
  createdAt    DateTime @default(now())

  chat       ClubChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderTrip Trip     @relation("ClubChatMessageSenderTrip", fields: [senderTripId], references: [id], onDelete: Cascade)
  senderUser User     @relation("ClubChatMessageSenderUser", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([senderTripId])
}

model ClubChatSplitExpense {
  id              String   @id @default(cuid())
  chatId          String
  desc            String
  amount          Float
  paidByKey       String
  splitWithKeys   String[]
  createdByTripId String
  createdByUserId String
  createdAt       DateTime @default(now())

  chat ClubChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}
